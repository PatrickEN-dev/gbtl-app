# =========================================================================
# GBTL — Environment variables
# Copie esse arquivo para .env e preencha com os valores reais antes de
# rodar `expo start`. NUNCA commite o .env real — só o .env.example.
#
# Em produção: configure essas variáveis em EAS Secrets:
#   eas secret:create --name STRIPE_PUBLISHABLE_KEY --value pk_live_...
# =========================================================================

# -------------------------------------------------------------------------
# 1. Backend API
# -------------------------------------------------------------------------
# URL do seu backend (Firestore REST, Cloud Functions, ou API própria).
# Em dev, pode ser localhost / ngrok.
EXPO_PUBLIC_API_URL=https://api.example.com

# -------------------------------------------------------------------------
# 2. Google OAuth (Sign-In)
# Cole os 3 Client IDs criados no Google Cloud Console > Credentials.
# Detalhes em SETUP.md § 1.
# -------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=000000000000-mockiosclientid.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=000000000000-mockandroidclientid.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=000000000000-mockwebclientid.apps.googleusercontent.com

# -------------------------------------------------------------------------
# 3. Stripe (Payment Sheet)
# Pegue em https://dashboard.stripe.com/apikeys
# - pk_test_... para dev, pk_live_... para prod
# - O endpoint precisa ser deployado separado (Vercel/Firebase) — ver SETUP.md § 2
# - merchantId para Apple Pay (precisa registrar em developer.apple.com)
# -------------------------------------------------------------------------
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_mock00000000000000000000000000000000000000000000000000
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.gbtl.app
EXPO_PUBLIC_STRIPE_PAYMENT_ENDPOINT=https://api.example.com/create-payment-intent

# -------------------------------------------------------------------------
# 4. Expo Push Notifications
# UUID do projeto em expo.dev (gerado via `eas init`).
# -------------------------------------------------------------------------
EXPO_PUBLIC_EXPO_PROJECT_ID=00000000-0000-0000-0000-000000000000

# -------------------------------------------------------------------------
# 5. Sentry (crash reporting)
# Crie projeto em sentry.io > Project > Client Keys.
# -------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=https://mock@o0000000.ingest.sentry.io/0000000
EXPO_PUBLIC_SENTRY_ENV=development

# -------------------------------------------------------------------------
# 6. PostHog (analytics)
# Crie projeto em posthog.com > Project settings > Project API Key.
# -------------------------------------------------------------------------
EXPO_PUBLIC_POSTHOG_API_KEY=phc_mockprojectapikey0000000000000000000000000000000
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -------------------------------------------------------------------------
# 7. App configuration
# -------------------------------------------------------------------------
EXPO_PUBLIC_APP_VARIANT=development
EXPO_PUBLIC_USE_MOCK_DATA=true

# -------------------------------------------------------------------------
# 8. Backend-only (NUNCA exponha no app — fica no servidor serverless)
# Estas variáveis não levam o prefixo EXPO_PUBLIC_ porque NÃO devem
# acabar no bundle do cliente. Use em config Vercel/Firebase apenas.
# -------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_mock00000000000000000000000000000000000000000000000000
# FIREBASE_ADMIN_KEY_BASE64=...
